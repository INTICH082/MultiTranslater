{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MultiTranslate",
  "version": "0.4.0",
  "identifier": "com.multitranslate.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:vite",
    "beforeBuildCommand": "npm run build:vite",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MultiTranslate",
        "url": "index.html",
        "width": 380,
        "height": 520,
        "resizable": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}